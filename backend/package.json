{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "GULUX_ENV=dev gulux dev --root . --config src/config --tsc",
    "build": "gulux build --root . --config src/config",
    "start": "NODE_ENV=production gulux start --root . --config src/config",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@gulux/cli": "^1.25.16",
    "@gulux/gulux": "^4.1.0",
    "@langchain/langgraph": "^1.3.0",
    "@next-ai/fornax-sdk": "^2.4.5",
    "dotenv": "^16.6.1",
    "mongodb": "^7.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@gulux/style": "^1.0.4",
    "@types/node": "^22.19.19",
    "ts-node": "^10.9.2"
  }
}
