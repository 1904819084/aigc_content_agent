{
  "extends": "@gulux/style/lib",
  "compilerOptions": {
    "outDir": "output",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "exclude": [
    ".gulux",
    "coverage",
    "log",
    "node_modules",
    "output",
    "test",
    ".bootstrap.ts",
    "bootstrap.ts",
    "*.json",
    "*.md"
  ],
  "include": ["src/**/*.ts"],
  "ts-node": {
    "files": true
  }
}
