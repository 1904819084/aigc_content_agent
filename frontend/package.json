    "react-router-dom": "^6.28.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "less": "^4.6.4",
    "typescript": "^5.5.4",
    "vite": "^5.3.4"
